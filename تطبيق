function bestOf(h,hi){ if(!h.length)return null; const v=h.map(e=>e.v); return hi?Math.max(...v):Math.min(...v); }
function trendOf(h,hi){ if(h.length<2)return null; const a=h[h.length-2].v,b=h[h.length-1].v; if(a===b)return{cls:'flat',txt:'↔ ثابت عن آخر مرة'};
  const better=hi?b>a:b<a; const diff=Math.abs(b-a).toFixed(1); return better?{cls:'up',txt:`↑ تحسّن بـ ${diff} 👏`}:{cls:'down',txt:`↓ تراجع بـ ${diff}`}; }
function pushVal(id,hi,entry){ const h=state.tests[id]=state.tests[id]||[]; const prevBest=h.length?bestOf(h,hi):null;
  h.push(entry); const isPR=prevBest!=null&&(hi?entry.v>prevBest:entry.v<prevBest);
  renderTests(); save(true); toast(isPR?'🏆 رقم قياسي جديد! أحسنت':'✓ حُفظ',isPR); }
function addTest(id,hi){ const inp=document.getElementById('in_'+id); const v=parseFloat(inp.value); if(isNaN(v)){alert('أدخل رقماً');return;}
