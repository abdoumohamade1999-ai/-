function svgChart(pts,color){ color=color||'#c8ff2e'; const W=320,H=140,pad=26; const vals=pts.map(p=>p.v); const min=Math.min(...vals),max=Math.max(...vals),rng=(max-min)||1;
  const x=i=>pad+i*(W-2*pad)/((pts.length-1)||1),y=v=>H-pad-(v-min)/rng*(H-2*pad);
  const line=pts.map((p,i)=>`${i?'L':'M'}${x(i).toFixed(1)},${y(p.v).toFixed(1)}`).join(' ');
  const area=`M${x(0).toFixed(1)},${(H-pad).toFixed(1)} `+pts.map((p,i)=>`L${x(i).toFixed(1)},${y(p.v).toFixed(1)}`).join(' ')+` L${x(pts.length-1).toFixed(1)},${(H-pad).toFixed(1)} Z`;
  const dots=pts.map((p,i)=>`<circle cx="${x(i).toFixed(1)}" cy="${y(p.v).toFixed(1)}" r="3" fill="${color}"/>`).join('');
  return `<div dir="ltr"><svg viewBox="0 0 ${W} ${H}" style="width:100%;height:140px">
    <line x1="${pad}" y1="${H-pad}" x2="${W-pad}" y2="${H-pad}" stroke="#262b30"/>
    <path d="${area}" fill="${color}1f"/><path d="${line}" fill="none" stroke="${color}" stroke-width="2.5"/>${dots}
    <text x="${pad-4}" y="${y(max).toFixed(1)}" fill="#8b969d" font-size="9" text-anchor="end">${Math.round(max*10)/10}</text>
    <text x="${pad-4}" y="${(H-pad).toFixed(1)}" fill="#8b969d" font-size="9" text-anchor="end">${Math.round(min*10)/10}</text>
    <text x="${pad}" y="${H-6}" fill="#8b969d" font-size="8">${pts[0].date||''}</text>
    <text x="${W-pad}" y="${H-6}" fill="#8b969d" font-size="8" text-anchor="end">${pts[pts.length-1].date||''}</text></svg></div>`; }
function svgBars(items){ const W=320,H=140,pad=24; const max=Math.max(...items.map(i=>i.v),1); const n=items.length; const slot=(W-2*pad)/n; const bw=slot*0.62;
  const bars=items.map((it,i)=>{ const h=(it.v/max)*(H-2*pad); const x=pad+i*slot+(slot-bw)/2; const y=H-pad-h;
    return `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${bw.toFixed(1)}" height="${Math.max(h,1).toFixed(1)}" rx="3" fill="#c8ff2e"/>`; }).join('');
  return `<div dir="ltr"><svg viewBox="0 0 ${W} ${H}" style="width:100%;height:140px">
    <line x1="${pad}" y1="${H-pad}" x2="${W-pad}" y2="${H-pad}" stroke="#262b30"/>${bars}
    <text x="${pad-4}" y="${pad+4}" fill="#8b969d" font-size="9" text-anchor="end">${Math.round(max)}</text>
    <text x="${pad}" y="${H-6}" fill="#8b969d" font-size="8">${items[0].label}</text>
    <text x="${W-pad}" y="${H-6}" fill="#8b969d" font-size="8" text-anchor="end">${items[items.length-1].label}</text></svg></div>`; }
