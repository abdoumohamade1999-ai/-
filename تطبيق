// ---- analysis ----
function doAnalyze(){
  let out='';
  const a=acwrCalc();
  out+=a.ok?`📊 حمل التدريب (ACWR): ${a.ratio.toFixed(2)} — ${a.zone}\n${a.advice}\n\n`:`📊 ${a.msg}\n\n`;
  const tw=[0,1,2,3,4,5,6].reduce((s,i)=>s+loadOn(daysAgoISO(i)),0);
  const lw=[7,8,9,10,11,12,13].reduce((s,i)=>s+loadOn(daysAgoISO(i)),0);
  if(lw>0)out+=`⚖️ حمل هذا الأسبوع: ${tw} مقابل ${lw} الأسبوع الماضي (${Math.round(tw/lw*100)}%). الزيادة الآمنة لا تتجاوز ~110-120%.\n\n`;
  const cb=consecBad(); if(cb>=3)out+=`🔻 ${cb} أيام متتالية بدون جاهزية خضراء — خذ أسبوع تخفيف (نصف الحجم، شدّة خفيفة).\n\n`;
  const rr=rhrRising(); if(rr)out+=`❤️ نبض راحتك في ارتفاع تدريجي (+${Math.round(rr)}) — إنذار مبكر، راقب نومك وحملك قبل أن تتعب فعلاً.\n\n`;
  if(sleepShort())out+=`😴 متوسط نومك آخر 3 ليالٍ أقل من 6.5س — دين النوم يبطئ كل تطوّرك. أصلحه أولاً.\n\n`;
  // tests
  let improving=[],declining=[],flat=[],best=null,goalsHit=[],goalsNear=[];
  Object.keys(CATS).forEach(cat=>CATS[cat].tests.forEach(t=>{ const h=state.tests[t.id]; if(!h||!h.length)return;
    const g=getGoal(t.id),b=bestOf(h,t.hi);
    if(g&&b!=null){ const pct=t.hi?b/g*100:g/b*100; if(pct>=100)goalsHit.push(t.n); else if(pct>=85)goalsNear.push(`${t.n} (${pct.toFixed(0)}%)`); }
    if(h.length<2)return; const f=h[0].v,l=h[h.length-1].v; const better=t.hi?l>f:l<f; const pc=Math.abs((l-f)/(f||1)*100);
    if(Math.abs(l-f)<0.01)flat.push(t.n); else if(better){improving.push(t.n); if(!best||pc>best.pc)best={n:t.n,pc};} else declining.push({n:t.n,pc,tip:tipFor(t.id)}); }));
  if(best)out+=`🏆 أكبر تطوّر: ${best.n} (+${best.pc.toFixed(0)}%). أحسنت!\n\n`;
  if(goalsHit.length)out+=`🎯 أهداف حقّقتها: ${goalsHit.join('، ')} — ارفع السقف وحدّد هدفاً جديداً!\n\n`;
  if(goalsNear.length)out+=`📍 قريب جداً من الهدف: ${goalsNear.join('، ')}.\n\n`;
  if(improving.length)out+=`📈 تتطوّر في: ${improving.join('، ')}.\n\n`;
  if(flat.length)out+=`↔ ثابت (يحتاج دفعة): ${flat.join('، ')}.\n\n`;
  if(declining.length){out+=`⚠️ تراجع — انتبه:\n`;declining.forEach(d=>out+=`• ${d.n} (−${d.pc.toFixed(0)}%): ${d.tip}\n`);out+='\n';}
  const recs=[];
  if(declining.length||flat.length)recs.push('اجعل ما تراجع أو ثبت "حركة تركيزك" القادمة بتكرار شبه يومي.');
  if(a.ok&&a.ratio>=0.8&&a.ratio<=1.3&&improving.length)recs.push('حملك آمن وتطوّرك مستمر — الوصفة الصحيحة، لا تغيّرها.');
  recs.push('أعد الاختبارات كل 2-4 أسابيع وأنت مرتاح (لا تختبر متعباً — النتيجة تضلّل).');
  out+='🧭 التوصية:\n'+recs.map(r=>'• '+r).join('\n');
  document.getElementById('anOut').innerHTML=`<div class="ai-out"><div class="h">🔬 تحليل المحرّك</div>${esc(out)}</div>`; renderAcwr(); }
function tipFor(id){ const m={juggle:'زد اللمسة اليومية للكرة.',slalom:'تمارين مراوغة بين المخاريط + رشاقة.',wallpass:'عمل تمرير ورودو أكثر.',shoot_curve:'زد حجم التسديد المنحني بتقنية صحيحة.',shoot_straight:'زد حجم التسديد المستقيم القوي.',weakshoot:'ركّز على الرجل الضعيفة يومياً.',
  sprint20:'بليومتركس + قوة سكوات + ميكانيكا الانطلاق.',vjump:'قفزات بليومترية + قوة أرجل.',longjump:'قوة انفجارية أفقية وقفزات.',wtest:'تمارين تغيير اتجاه ورشاقة.',plank:'عمل جذع منتظم يومياً.',rsa:'تكرار انطلاقات + قاعدة هوائية.',
  pushup:'عمل علوي تدريجي.',bwsquat:'تحمّل عضلي للأرجل.',pullup:'تدرّج بالعقلة (مساعدة بالمطاط).',barsquat:'تدرّج تصاعدي في وزن السكوات.',deadlift:'تدرّج في الدِّدلِفت بتقنية سليمة.',legext:'زد وزن العضلة الأمامية تدريجياً.',legcurl:'زد وزن العضلة الخلفية تدريجياً.'};
  return m[id]||'زد التركيز عليها تدريجياً.'; }

