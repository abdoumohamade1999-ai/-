function needsRetest(h){ if(!h||!h.length)return false; const last=h[h.length-1]; if(!last.dateISO)return false; return daysBetween(last.dateISO,todayISO())>=21; }
function renderTests(){ const c=document.getElementById('testList'); if(!c)return; c.innerHTML='';
  let dueCount=0; Object.keys(CATS).forEach(cat=>CATS[cat].tests.forEach(t=>{ if(needsRetest(state.tests[t.id]))dueCount++; }));
  document.getElementById('dueNote').innerHTML=dueCount?`<div class="note"><b>⏰ ${dueCount} اختبارات</b> مرّ عليها 3+ أسابيع — حان وقت إعادة القياس لتتبّع تطوّرك بدقة.</div>`:'';
  CATS[curCat].tests.forEach(t=>{ const hist=state.tests[t.id]||[]; const best=bestOf(hist,t.hi); const trend=trendOf(hist,t.hi); const last=hist[hist.length-1]; const due=needsRetest(hist);
    const goal=getGoal(t.id); let goalRow='';
    if(true){ let pct=null; if(goal&&best!=null){ pct=t.hi?best/goal*100:goal/best*100; pct=Math.min(100,Math.max(0,pct)); }
      goalRow=`<div class="goalrow"><span>🎯 هدف:</span><input type="number" step="any" class="num" value="${goal!=null?goal:''}" placeholder="—" onchange="setGoal('${t.id}',this.value)">
