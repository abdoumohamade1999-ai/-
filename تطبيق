    let entry,lastTxt='';
    if(t.wr){ entry=`<div class="entry"><input type="number" step="any" id="w_${t.id}" class="num" placeholder="وزن (كغ)"><input type="number" step="any" id="r_${t.id}" class="num" placeholder="تكرار"><button onclick="addWR('${t.id}')">سجّل</button></div>`;
      if(last)lastTxt=`<div class="last">آخر: ${last.w}كغ × ${last.reps} (مُقدّر ≈ ${Math.round(last.v)}كغ) · ${last.date||''}</div>`; }
    else { entry=`<div class="entry"><input type="number" step="any" id="in_${t.id}" class="num" placeholder="نتيجة اليوم (${t.u})"><button onclick="addTest('${t.id}',${t.hi})">سجّل</button></div>`;
      if(last)lastTxt=`<div class="last">آخر: ${last.v} ${t.u} · ${last.date||''}</div>`; }
    const el=document.createElement('div'); el.className='test';
    el.innerHTML=`<div class="th"><div><b>${t.n}</b><small> (${t.u})</small>${due?'<br><span class="due">⏰ أعد الاختبار</span>':''}</div>
