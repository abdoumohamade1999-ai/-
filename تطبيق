<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>المختبر الذكي</title>
<meta name="theme-color" content="#0a0b0c">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<meta name="apple-mobile-web-app-title" content="المختبر">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<link rel="icon" type="image/png" href="icon-192.png">
<style>
@font-face{font-family:'Almarai';font-style:normal;font-weight:400;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0600-06FF,U+0750-077F,U+FB50-FDFF,U+FE70-FEFF;}
@font-face{font-family:'Almarai';font-style:normal;font-weight:400;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+2000-206F,U+2074,U+20AC,U+2122,U+2191,U+2193,U+2212,U+FEFF,U+FFFD;}
@font-face{font-family:'Almarai';font-style:normal;font-weight:700;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0600-06FF,U+0750-077F,U+FB50-FDFF,U+FE70-FEFF;}
@font-face{font-family:'Almarai';font-style:normal;font-weight:700;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+2000-206F,U+2074,U+20AC,U+2122,U+2191,U+2193,U+2212,U+FEFF,U+FFFD;}
@font-face{font-family:'Almarai';font-style:normal;font-weight:800;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0600-06FF,U+0750-077F,U+FB50-FDFF,U+FE70-FEFF;}
@font-face{font-family:'Almarai';font-style:normal;font-weight:800;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+2000-206F,U+2074,U+20AC,U+2122,U+2191,U+2193,U+2212,U+FEFF,U+FFFD;}
@font-face{font-family:'Anton';font-style:normal;font-weight:400;font-display:swap;src:url(data:font/woff2;base64,) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+2000-206F,U+2074,U+20AC,U+2122,U+2191,U+2193,U+2212,U+FEFF,U+FFFD;}
</style>

<style>
  :root{--bg:#0a0b0c;--card:#16191c;--card2:#1d2125;--line:#262b30;--txt:#eef2f3;--mut:#8b969d;--lime:#c8ff2e;--lime-d:#9fcf17;--amber:#ffbe2e;--red:#ff5252;--blue:#4dc3ff;--gold:#ffd24d;}
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{background:var(--bg);color:var(--txt);font-family:'Almarai',sans-serif;}
  body{max-width:520px;margin:0 auto;min-height:100vh;padding-bottom:80px;overflow-x:hidden;
    background-image:radial-gradient(circle at 12% 0%, rgba(200,255,46,.07), transparent 40%),radial-gradient(circle at 88% 6%, rgba(77,195,255,.05), transparent 38%);}
  .anton{font-family:'Anton',sans-serif;}
  header{padding:22px 20px 10px;}
  .kicker{color:var(--lime);font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;}
  header h1{font-size:25px;font-weight:800;margin-top:3px;} header h1 span{color:var(--lime);}
  .hsub{color:var(--mut);font-size:12px;margin-top:4px;}
  .offline{display:inline-block;background:rgba(77,195,255,.12);color:var(--blue);font-size:10px;font-weight:800;padding:3px 9px;border-radius:7px;margin-top:8px;}
  .view{padding:0 16px;display:none;animation:fade .35s ease;} .view.active{display:block;}
  @keyframes fade{from{opacity:0;transform:translateY(8px);}to{opacity:1;}}
  .sec-title{font-size:12px;font-weight:800;color:var(--mut);letter-spacing:1px;text-transform:uppercase;margin:18px 4px 11px;display:flex;align-items:center;gap:7px;} .sec-title .ln{flex:1;height:1px;background:var(--line);}
  .card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:17px;margin-bottom:13px;}
  .card h3{font-size:16px;font-weight:800;} .card p{color:var(--mut);font-size:13px;line-height:1.7;margin-top:5px;}
  .q{margin:14px 0;} .q-lbl{display:flex;justify-content:space-between;font-size:13.5px;font-weight:700;margin-bottom:9px;} .q-lbl small{color:var(--mut);font-weight:400;font-size:11px;}
  .scale{display:flex;gap:6px;} .scale button{flex:1;aspect-ratio:1;border-radius:11px;border:1px solid var(--line);background:var(--card2);color:var(--mut);font-family:'Anton';font-size:16px;cursor:pointer;transition:.18s;}
  .scale button.on{background:var(--lime);color:#0a0b0c;border-color:var(--lime);transform:scale(1.05);}
  input,textarea,select{background:var(--card2);border:1px solid var(--line);color:var(--txt);border-radius:12px;padding:12px;font-size:15px;font-family:'Almarai';width:100%;}
  input[type=time]{font-family:'Anton';color:var(--lime);text-align:center;}
  input::placeholder,textarea::placeholder{color:var(--mut);} .num{font-family:'Anton';text-align:center;color:var(--lime);}
  .two{display:flex;gap:9px;} .two>div{flex:1;} .two .sub{font-size:10.5px;color:var(--mut);text-align:center;margin-bottom:5px;}
  .btn{width:100%;background:var(--lime);color:#0a0b0c;border:none;border-radius:14px;padding:15px;font-family:'Almarai';font-size:15px;font-weight:800;cursor:pointer;margin-top:10px;transition:.18s;}
  .btn:active{transform:scale(.98);} .btn.ghost{background:var(--card2);color:var(--txt);border:1px solid var(--line);}
  .yopts{display:flex;flex-direction:column;gap:7px;}
  .yopts button{text-align:right;background:var(--card2);border:1px solid var(--line);color:var(--txt);border-radius:11px;padding:11px 14px;font-family:'Almarai';font-size:13px;cursor:pointer;display:flex;align-items:center;gap:9px;}
  .yopts button .ed{width:9px;height:9px;border-radius:50%;border:1.5px solid var(--mut);flex-shrink:0;}
  .yopts button.on{border-color:var(--lime);background:rgba(200,255,46,.08);} .yopts button.on .ed{background:var(--lime);border-color:var(--lime);}
  .autohint{font-size:11px;color:var(--lime);margin-top:7px;font-weight:700;}
  .verdict{border-radius:18px;padding:20px;margin-bottom:14px;border:1px solid;animation:fade .4s;}
  .verdict .top{display:flex;align-items:center;gap:12px;} .verdict .dot{font-size:34px;} .verdict h2{font-size:21px;font-weight:800;}
  .verdict .scoreline{font-size:11px;color:var(--mut);margin-top:2px;} .verdict .scoreline b{font-family:'Anton';font-size:14px;}
  .verdict p{font-size:13px;line-height:1.7;opacity:.95;margin-top:12px;white-space:pre-wrap;}
  .v-green{background:rgba(200,255,46,.1);border-color:var(--lime);} .v-green h2,.v-green .dot{color:var(--lime);}
  .v-amber{background:rgba(255,190,46,.1);border-color:var(--amber);} .v-amber h2,.v-amber .dot{color:var(--amber);}
  .v-red{background:rgba(255,82,82,.1);border-color:var(--red);} .v-red h2,.v-red .dot{color:var(--red);}
  .intens-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px;}
  .ig{background:rgba(0,0,0,.25);border-radius:11px;padding:10px 12px;} .ig small{color:var(--mut);font-size:10.5px;display:block;}
  .ig .lv{font-family:'Anton';font-size:12px;padding:3px 8px;border-radius:6px;margin-top:4px;display:inline-block;}
  .lv-full{background:var(--lime);color:#0a0b0c;} .lv-mid{background:var(--amber);color:#0a0b0c;} .lv-low{background:rgba(255,82,82,.2);color:var(--red);} .lv-no{background:var(--card2);color:var(--mut);}
  /* training log */
  .tchips{display:flex;gap:7px;flex-wrap:wrap;}
  .tchips button{background:var(--card2);border:1px solid var(--line);color:var(--mut);border-radius:20px;padding:8px 14px;font-size:12.5px;font-family:'Almarai';font-weight:700;cursor:pointer;}
  .tchips button.on{background:var(--lime);color:#0a0b0c;border-color:var(--lime);}
  .rpe{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;}
  .rpe button{aspect-ratio:1.5;border-radius:10px;border:1px solid var(--line);background:var(--card2);color:var(--mut);font-family:'Anton';font-size:15px;cursor:pointer;}
  .rpe button.on{background:var(--lime);color:#0a0b0c;border-color:var(--lime);}
  .loadprev{font-size:12px;color:var(--mut);margin-top:8px;} .loadprev b{font-family:'Anton';color:var(--lime);font-size:15px;}
  .sess{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:12px 14px;margin-bottom:9px;display:flex;align-items:center;gap:11px;}
  .sess .si{font-size:19px;} .sess .sm{flex:1;} .sess .sm b{font-size:13.5px;} .sess .sm small{display:block;color:var(--mut);font-size:11px;margin-top:2px;}
  .sess .sl{text-align:left;} .sess .sl b{font-family:'Anton';font-size:17px;color:var(--lime);display:block;} .sess .sl small{font-size:9px;color:var(--mut);}
  .sess .del{background:none;border:none;color:var(--mut);font-size:15px;cursor:pointer;padding:4px;}
  /* acwr */
  .acwr{border-radius:16px;border:1px solid var(--line);background:var(--card);padding:16px;margin-bottom:13px;}
  .acwr .ah{display:flex;justify-content:space-between;align-items:center;}
  .acwr .ah b{font-size:14px;} .acwr .ratio{font-family:'Anton';font-size:30px;}
  .acwr .zone{font-size:12px;font-weight:800;margin-top:4px;}
  .acwr .adv{font-size:12.5px;color:var(--mut);line-height:1.6;margin-top:8px;}
  .acwr .meter{height:10px;border-radius:8px;margin-top:11px;background:linear-gradient(90deg,#4dc3ff 0 20%,#c8ff2e 20% 60%,#ffbe2e 60% 75%,#ff5252 75% 100%);position:relative;}
  .acwr .pin{position:absolute;top:-4px;width:4px;height:18px;background:#fff;border-radius:3px;transform:translateX(50%);}
  .c-green{color:var(--lime);} .c-amber{color:var(--amber);} .c-red{color:var(--red);} .c-blue{color:var(--blue);}
  /* tests */
  .cat-tabs{display:flex;gap:7px;margin-bottom:12px;overflow-x:auto;padding-bottom:2px;}
  .cat-tabs button{white-space:nowrap;background:var(--card2);border:1px solid var(--line);color:var(--mut);border-radius:20px;padding:8px 15px;font-size:12.5px;font-family:'Almarai';font-weight:700;cursor:pointer;} .cat-tabs button.on{background:var(--lime);color:#0a0b0c;border-color:var(--lime);}
  .test{background:var(--card);border:1px solid var(--line);border-radius:15px;padding:15px;margin-bottom:11px;}
  .test .th{display:flex;justify-content:space-between;align-items:flex-start;gap:10px;}
  .test .th b{font-size:14.5px;font-weight:800;} .test .th small{color:var(--mut);font-size:11px;}
  .test .best{text-align:left;flex-shrink:0;} .test .best b{font-family:'Anton';font-size:19px;color:var(--lime);display:block;} .test .best small{font-size:9px;color:var(--mut);}
  .due{display:inline-block;background:rgba(255,190,46,.15);color:var(--amber);font-size:10px;font-weight:800;padding:2px 8px;border-radius:7px;margin-top:4px;}
  .test .desc{color:var(--mut);font-size:12px;line-height:1.6;margin:9px 0;}
  .test .entry{display:flex;gap:8px;align-items:center;} .test .entry input{flex:1;} .test .entry button{background:var(--lime);color:#0a0b0c;border:none;border-radius:11px;padding:0 16px;font-weight:800;font-family:'Almarai';cursor:pointer;white-space:nowrap;align-self:stretch;}
  .test .last{font-size:11px;color:var(--mut);margin-top:7px;}
  .test .trend{font-size:11px;margin-top:5px;font-weight:700;} .up{color:var(--lime);} .down{color:var(--red);} .flat{color:var(--mut);}
  .goalrow{display:flex;align-items:center;gap:8px;margin-top:10px;font-size:11.5px;color:var(--mut);}
  .goalrow input{width:64px;padding:7px;font-size:13px;}
  .gbar{flex:1;height:7px;background:var(--card2);border-radius:8px;overflow:hidden;} .gbar i{display:block;height:100%;background:linear-gradient(90deg,var(--lime-d),var(--lime));border-radius:8px;}
  .gpct{font-family:'Anton';font-size:12px;color:var(--lime);min-width:34px;text-align:left;}
  .note{background:var(--card2);border-right:3px solid var(--amber);border-radius:10px;padding:11px 13px;font-size:12px;color:var(--mut);line-height:1.6;margin:12px 0;} .note b{color:var(--amber);}
  .chart-card{background:var(--card);border:1px solid var(--line);border-radius:15px;padding:14px;margin-bottom:11px;}
  .chart-card .ct{font-size:13px;font-weight:800;margin-bottom:3px;} .chart-card .cs{font-size:10.5px;color:var(--mut);margin-bottom:6px;}
  .ai-out{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:16px;margin-top:12px;font-size:13.5px;line-height:1.9;white-space:pre-wrap;animation:fade .4s;} .ai-out .h{color:var(--lime);font-weight:800;font-size:11px;letter-spacing:1px;margin-bottom:8px;}
  .empty{text-align:center;color:var(--mut);font-size:13px;padding:24px 10px;}
  nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:520px;background:rgba(13,15,16,.94);backdrop-filter:blur(14px);border-top:1px solid var(--line);display:flex;padding:7px 6px 12px;z-index:50;}
  nav button{flex:1;background:none;border:none;color:var(--mut);font-family:'Almarai';font-size:10.5px;font-weight:700;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;padding:5px 0;} nav button .ni{font-size:19px;} nav button.on{color:var(--lime);}
  .toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%);background:var(--lime);color:#0a0b0c;padding:10px 20px;border-radius:30px;font-weight:800;font-size:13px;opacity:0;transition:.3s;z-index:60;pointer-events:none;}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(-6px);}
  .toast.gold{background:var(--gold);box-shadow:0 6px 24px rgba(255,210,77,.45);}
</style>
</head>
<body>

<header>
  <div class="kicker">★ المختبر البدني الذكي 2.0</div>
  <h1>المُختبَر <span>الذكي</span></h1>
  <div class="hsub">يقرأ أسابيعك لا يومك فقط — حمل تدريبي علمي (ACWR) وكشف أنماط</div>
  <span class="offline">✈ يعمل بدون إنترنت · يحفظ على جهازك</span>
</header>

<!-- DAILY -->
<section class="view active" id="v-daily">
  <div class="sec-title">فحص اليوم <span class="ln"></span></div>
  <div id="dailyResult"></div>
  <div class="card" id="dailyForm">
    <h3>كيف حالك اليوم؟ 🌅</h3>
    <p>كلما دقّقت في الأرقام، كان التحليل أذكى.</p>

    <div class="q"><div class="q-lbl">النوم<small>يحسب المدّة والجودة تلقائياً</small></div>
      <div class="two"><div><div class="sub">نمت الساعة</div><input type="time" id="d_bed" value="23:00"></div><div><div class="sub">استيقظت الساعة</div><input type="time" id="d_wake" value="07:00"></div></div></div>

    <div class="q"><div class="q-lbl">نبضات القلب في 30 ثانية<small>صباحاً في الفراش</small></div><input type="number" id="d_rhr30" class="num" placeholder="عدد النبضات في 30 ثانية"></div>

    <div class="q"><div class="q-lbl">ألم العضلات<small>5=بلا ألم</small></div><div class="scale" data-k="soreness"></div></div>
    <div class="q"><div class="q-lbl">الطاقة<small>1-5</small></div><div class="scale" data-k="energy"></div></div>
    <div class="q"><div class="q-lbl">المزاج/الدافعية<small>1-5</small></div><div class="scale" data-k="mood"></div></div>
    <div class="q"><div class="q-lbl">التوتر<small>5=مرتاح</small></div><div class="scale" data-k="stress"></div></div>

    <div class="sec-title" style="margin:16px 4px 8px">اختبارات بدنية سريعة</div>
    <div class="q"><div class="q-lbl">القفزة العمودية<small>مؤشر CNS — سم</small></div><input type="number" id="d_jump" class="num" placeholder="فرق وصولك واقفاً وبالقفز (سم)"></div>
    <div class="q"><div class="q-lbl">التوازن على رجل واحدة<small>عينان مغمضتان — ثانية</small></div><input type="number" id="d_balance" class="num" placeholder="أقصى مدة ثبات (ثانية)"></div>
    <div class="q"><div class="q-lbl">المرونة (الجلوس والوصول)<small>سم</small></div><input type="number" id="d_flex" class="num" placeholder="المسافة لأصابع القدم (+/−)"></div>

    <div class="q"><div class="q-lbl">ماذا تدرّبت البارحة؟<small></small></div>
      <div class="yopts" id="yopts"></div><div id="yHint"></div></div>

    <div class="q"><div class="q-lbl">أي شيء آخر؟<small>اختياري</small></div><textarea id="d_note" rows="2" placeholder="إصابة خفيفة، سفر..."></textarea></div>
    <button class="btn" onclick="doDaily()">حدّد شدّة تدريبي ⚡</button>
  </div>
  <div class="note"><b>القفزة:</b> علّم أقصى وصول واقفاً ثم بالقفز على حائط، الفرق = ارتفاعها. <b>التوازن:</b> قف على رجل وأغمض عينيك. <b>المرونة:</b> اجلس وساقاك ممدودتان ومدّ يديك لأصابع قدميك.</div>
</section>

<!-- TRAINING LOG -->
<section class="view" id="v-train">
  <div class="sec-title">سجّل تدريب اليوم <span class="ln"></span></div>
  <div class="card">
    <h3>ماذا تدرّبت؟ 📝</h3>
    <p>سجّل كل حصة — المحرّك يحسب حملك التدريبي ويعبّي "نشاط البارحة" تلقائياً غداً.</p>
    <div class="q"><div class="q-lbl">نوع التدريب<small></small></div><div class="tchips" id="tchips"></div></div>
    <div class="q"><div class="q-lbl">الشدّة المحسوسة (RPE)<small>1 سهل جداً · 10 أقصى جهد</small></div><div class="rpe" id="rpe"></div></div>
    <div class="q"><div class="q-lbl">المدّة<small>بالدقائق</small></div><input type="number" id="t_dur" class="num" placeholder="دقيقة"></div>
    <div class="loadprev" id="loadPrev"></div>
    <div class="q"><div class="q-lbl">ملاحظة<small>اختياري</small></div><input type="text" id="t_note" placeholder="مثلاً: 1v1 + تسديد ضعيف"></div>
    <button class="btn" onclick="addSession()">سجّل الحصة</button>
  </div>
  <div id="acwrTrain"></div>
  <div class="sec-title">آخر الحصص <span class="ln"></span></div>
  <div id="sessList"></div>
</section>

<!-- TESTS -->
<section class="view" id="v-tests">
  <div class="sec-title">الاختبارات البدنية الفردية <span class="ln"></span></div>
  <div id="dueNote"></div>
  <div class="cat-tabs" id="catTabs"></div>
  <div id="testList"></div>
  <div class="note"><b>أمان رفع الأثقال:</b> لا تجرّب أقصى وزن وحدك. سجّل وزناً مريحاً وتكراراته والمحرّك يقدّر قوتك القصوى. حدّد هدفاً 🎯 لكل اختبار لتشاهد تقدّمك نحوه.</div>
</section>

<!-- ANALYSIS -->
<section class="view" id="v-analysis">
  <div class="sec-title">التحليل والرسوم <span class="ln"></span></div>
  <div id="acwrAn"></div>
  <div class="card">
    <h3>دراسة تطوّرك 📈</h3>
    <p>المحرّك يقرأ حملك وأنماط جاهزيتك ونتائج اختباراتك معاً.</p>
    <button class="btn" onclick="doAnalyze()">حلّل تطوّري</button>
  </div>
  <div id="anOut"></div>
  <div class="sec-title">اتجاهات الجاهزية والحمل <span class="ln"></span></div>
  <div id="wellCharts"></div>
  <div class="sec-title">منحنيات الاختبارات <span class="ln"></span></div>
  <div id="charts"></div>
  <div class="sec-title">نسخة احتياطية <span class="ln"></span></div>
  <div class="card">
    <h3>💾 بياناتك ملكك</h3>
    <p>صدّر نسخة دورياً — لا تخسر شهوراً من البيانات لو تغيّر الهاتف.</p>
    <button class="btn ghost" onclick="exportData()">تصدير بياناتي</button>
