<script>
// ---- offline storage ----
let mem={};
const store={ get(k){try{const v=localStorage.getItem(k);return v!=null?v:(mem[k]||null);}catch(e){return mem[k]||null;}},
  set(k,v){try{localStorage.setItem(k,v);}catch(e){mem[k]=v;}} };

let state={ daily:{soreness:0,energy:0,mood:0,stress:0,yesterday:null}, lastDaily:null, lastCheckISO:null,
  dailyLog:[], tests:{}, trainLog:[], goals:{} };
let curCat='football', autoFilled=false, selType=null, selRPE=0;

// ---- dates ----
function isoLocal(d){const y=d.getFullYear(),m=String(d.getMonth()+1).padStart(2,'0'),dd=String(d.getDate()).padStart(2,'0');return y+'-'+m+'-'+dd;}
function todayISO(){return isoLocal(new Date());}
function daysAgoISO(n){const d=new Date();d.setDate(d.getDate()-n);return isoLocal(d);}
function daysBetween(a,b){return Math.round((new Date(b)-new Date(a))/86400000);}
function disp(){return new Date().toLocaleDateString('ar-EG');}
function avg(arr){return arr.reduce((a,b)=>a+b,0)/(arr.length||1);}

const YEST=[
  ['endur_hard','🔴 تدريب تحمّل قاسٍ البارحة'],['endur_mid','🟠 تدريب تحمّل متوسط البارحة'],['endur_light','🟢 تدريب تحمّل خفيف البارحة'],
  ['str_hard','🔴 تدريب قوة قاسٍ البارحة'],['str_mid','🟠 تدريب قوة متوسط البارحة'],['str_light','🟢 تدريب قوة خفيف البارحة'],
  ['rest','💤 لم أتدرّب البارحة']];
const RANK={str_hard:6,endur_hard:6,str_mid:4,endur_mid:4,str_light:2,endur_light:2,rest:0};
const TTYPES={strength:{lbl:'قوة',ic:'💪'},endurance:{lbl:'تحمّل',ic:'🫁'},speed:{lbl:'سرعة',ic:'⚡'},skill:{lbl:'مهارة',ic:'⚽'},match:{lbl:'مباراة',ic:'🏟️'}};

const CATS={
  football:{name:'كرة القدم',icon:'⚽',tests:[
    {id:'juggle',n:'التحكّم (Juggling)',u:'لمسة',hi:true,d:'عُدّ أقصى لمسات متتالية بلا سقوط.'},
    {id:'slalom',n:'المراوغة (سلالوم)',u:'ثانية',hi:false,d:'5 مخاريط كل 2م، راوغها ذهاباً وإياباً ووقّت.'},
    {id:'wallpass',n:'التمرير (حائط)',u:'تمريرة',hi:true,d:'مرّر للحائط بلمستين، عُدّ الصحيحة في 45 ثانية.'},
    {id:'shoot_curve',n:'دقّة التسديد المنحني',u:'/10',hi:true,d:'10 تسديدات منحنية على زاوية المرمى، عُدّ الإصابات.'},
    {id:'shoot_straight',n:'دقّة التسديد المستقيم',u:'/10',hi:true,d:'10 تسديدات مستقيمة قوية على الزاوية، عُدّ الإصابات.'},
    {id:'weakshoot',n:'التسديد بالرجل الضعيفة',u:'/10',hi:true,d:'10 تسديدات بالرجل اليمنى، عُدّ الإصابات.'}
  ]},
  athletic:{name:'الجسم والسرعة',icon:'🏃',tests:[
    {id:'sprint20',n:'سرعة 20م',u:'ثانية',hi:false,d:'علّم 20م، انطلق من وقفة، وقّت.'},
    {id:'vjump',n:'القفزة العمودية',u:'سم',hi:true,d:'فرق أقصى وصول واقفاً وبالقفز على حائط.'},
    {id:'longjump',n:'الوثب الطويل من الثبات',u:'سم',hi:true,d:'اقفز للأمام من الثبات، قِس المسافة.'},
    {id:'wtest',n:'الرشاقة (W-test)',u:'ثانية',hi:false,d:'رتّب المخاريط على شكل W واجرِ متتبّعاً الشكل بأقصى سرعة، ووقّت.'},
    {id:'plank',n:'ثبات الجذع (بلانك)',u:'ثانية',hi:true,d:'بلانك بتقنية سليمة، وقّت أقصى مدة.'},
    {id:'rsa',n:'تكرار الانطلاقات',u:'ثانية',hi:false,d:'6×20م بأقصى سرعة، راحة 20ث، اجمع كل الأزمنة.'}
  ]},
  strength:{name:'القوة',icon:'💪',tests:[
    {id:'pushup',n:'أقصى ضغط (Push-ups)',u:'تكرار',hi:true,d:'أقصى عدد بتقنية سليمة بلا توقّف.'},
    {id:'bwsquat',n:'سكوات وزن الجسم 60ث',u:'تكرار',hi:true,d:'أقصى سكوات كامل في 60 ثانية.'},
    {id:'pullup',n:'العقلة (Pull-ups)',u:'تكرار',hi:true,d:'أقصى عدد بلا تأرجح.'},
    {id:'barsquat',n:'السكوات بالبار',u:'كغ',hi:true,wr:true,d:'سجّل الوزن والتكرارات، يقدّر المحرّك قوتك القصوى.'},
    {id:'deadlift',n:'الدِّدلِفت (Deadlift)',u:'كغ',hi:true,wr:true,d:'سجّل الوزن والتكرارات.'},
    {id:'legext',n:'تمديد الساق (العضلة الأمامية)',u:'كغ',hi:true,wr:true,d:'آلة الجلوس ورفع القدمين — سجّل الوزن والتكرارات.'},
    {id:'legcurl',n:'ثني الساق (العضلة الخلفية)',u:'كغ',hi:true,wr:true,d:'الاستلقاء على البطن ورفع القدمين بوزن — سجّل الوزن والتكرارات.'}
  ]}
};
const DEFAULT_GOALS={juggle:150,wallpass:30,shoot_curve:7,shoot_straight:7,weakshoot:7,sprint20:3.0,vjump:55,longjump:230,plank:120,pushup:40,bwsquat:45,pullup:12,barsquat:122,deadlift:135};

function nav(v,el){ document.querySelectorAll('.view').forEach(s=>s.classList.remove('active')); document.getElementById('v-'+v).classList.add('active');
  document.querySelectorAll('nav button').forEach(b=>b.classList.remove('on')); el.classList.add('on'); window.scrollTo({top:0,behavior:'smooth'});
  if(v==='analysis'){renderAcwr();renderWellCharts();renderCharts();} if(v==='train'){renderAcwr();renderSess();} if(v==='tests'){renderTests();} }

function load(){ const r=store.get('fitlab:data'); if(r){try{state=Object.assign(state,JSON.parse(r));}catch(e){}}
  const t=todayISO();
  if(state.lastCheckISO && state.lastCheckISO!==t){ state.lastDaily=null; state.daily={soreness:0,energy:0,mood:0,stress:0,yesterday:null}; }
  if(!state.daily.yesterday){ const a=autoYesterday(); if(a){state.daily.yesterday=a; autoFilled=true;} }
  buildScales(); buildYest(); buildTrainForm(); renderDaily(); renderCats(); renderTests(); renderSess(); renderAcwr(); }
function save(silent,gold){ store.set('fitlab:data',JSON.stringify(state)); if(!silent)toast(gold?'🏆 رقم قياسي جديد! أحسنت':'✓ حُفظ على جهازك',gold); }
function toast(txt,gold){ const t=document.getElementById('toast'); t.textContent=txt||'✓ حُفظ'; t.classList.toggle('gold',!!gold); t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),gold?2200:1300); }

// ---- training log ----
function buildTrainForm(){ const tc=document.getElementById('tchips'); tc.innerHTML='';
  Object.keys(TTYPES).forEach(k=>{ const b=document.createElement('button'); b.textContent=TTYPES[k].ic+' '+TTYPES[k].lbl; if(selType===k)b.classList.add('on');
    b.onclick=()=>{selType=k;buildTrainForm();}; tc.appendChild(b); });
  const rp=document.getElementById('rpe'); rp.innerHTML='';
  for(let i=1;i<=10;i++){ const b=document.createElement('button'); b.textContent=i; if(selRPE===i)b.classList.add('on');
    b.onclick=()=>{selRPE=i;buildTrainForm();updLoad();}; rp.appendChild(b); }
  updLoad(); const di=document.getElementById('t_dur'); di.oninput=updLoad; }
function updLoad(){ const dur=parseFloat(document.getElementById('t_dur').value)||0; const el=document.getElementById('loadPrev');
  el.innerHTML=(selRPE&&dur)?`حمل الحصة = شدّة × دقائق = <b>${selRPE*dur}</b> وحدة`:'حمل الحصة = الشدّة × الدقائق'; }
function addSession(){ const dur=parseFloat(document.getElementById('t_dur').value);
  if(!selType){alert('اختر نوع التدريب');return;} if(!selRPE){alert('اختر الشدّة (RPE)');return;} if(isNaN(dur)||dur<=0){alert('أدخل المدّة بالدقائق');return;}
  const note=document.getElementById('t_note').value;
  state.trainLog.push({dateISO:todayISO(),date:disp(),type:selType,rpe:selRPE,dur,load:Math.round(selRPE*dur),note});
  selType=null;selRPE=0;document.getElementById('t_dur').value='';document.getElementById('t_note').value='';
  buildTrainForm(); renderSess(); renderAcwr(); save(); }
function delSession(i){ if(!confirm('حذف هذه الحصة؟'))return; state.trainLog.splice(i,1); renderSess(); renderAcwr(); save(true); }
function renderSess(){ const c=document.getElementById('sessList'); if(!c)return;
  if(!state.trainLog.length){c.innerHTML='<div class="empty">لم تسجّل حصصاً بعد.</div>';return;} c.innerHTML='';
  state.trainLog.slice(-20).reverse().forEach((s,ri)=>{ const i=state.trainLog.length-1-ri; const t=TTYPES[s.type]||{ic:'🏋️',lbl:s.type};
    const el=document.createElement('div'); el.className='sess';
    el.innerHTML=`<span class="si">${t.ic}</span><div class="sm"><b>${t.lbl} · ${s.date}</b><small>RPE ${s.rpe} × ${s.dur} دقيقة${s.note?' · '+esc(s.note):''}</small></div>
      <div class="sl"><b>${s.load}</b><small>وحدة حمل</small></div><button class="del" onclick="delSession(${i})">✕</button>`;
    c.appendChild(el); }); }

function loadOn(iso){ return state.trainLog.filter(s=>s.dateISO===iso).reduce((a,s)=>a+(s.load||0),0); }
function acwrCalc(){ const w=state.trainLog.filter(s=>s.dateISO); if(!w.length)return{ok:false,msg:'سجّل حصصك في تبويب التدريب ليُحسب حملك (ACWR).'};
  const firstISO=w.map(s=>s.dateISO).sort()[0]; const span=daysBetween(firstISO,todayISO());
  let acute=0,chronic=0; for(let i=0;i<28;i++){const L=loadOn(daysAgoISO(i)); chronic+=L; if(i<7)acute+=L;}
  const chronicWeekly=chronic/4;
  if(span<10||chronicWeekly<=0)return{ok:false,msg:'بيانات الحمل غير كافية بعد — استمر بالتسجيل ~10 أيام ليصبح ACWR موثوقاً.',acute};
  const ratio=acute/chronicWeekly; let zone,cls,advice;
  if(ratio>1.5){zone='⚠️ منطقة خطر الإصابة';cls='red';advice='حملك قفز بسرعة كبيرة عن معتادك — خفّف هذا الأسبوع فوراً (قلّل الحجم 30-50%).';}
  else if(ratio>1.3){zone='حذر — حمل مرتفع';cls='amber';advice='تقترب من الحد. لا تزد الحمل أكثر هذا الأسبوع وراقب نومك ونبضك.';}
  else if(ratio>=0.8){zone='✅ النطاق الآمن الأمثل';cls='green';advice='حملك متدرّج وآمن — هذا بالضبط ما يبني التطوّر بدون إصابة. استمر.';}
  else {zone='حمل منخفض';cls='blue';advice='حملك أقل من معتادك — إن لم يكن أسبوع تخفيف مقصوداً، يمكنك الدفع أكثر بأمان.';}
  return{ok:true,ratio,zone,cls,advice,acute,chronicWeekly}; }
function acwrHTML(){ const a=acwrCalc();
  if(!a.ok)return `<div class="acwr"><div class="ah"><b>📊 حمل التدريب (ACWR)</b></div><div class="adv">${a.msg}</div></div>`;
  const pos=Math.min(100,Math.max(0,a.ratio/2*100));
  return `<div class="acwr"><div class="ah"><b>📊 حمل التدريب (ACWR)</b><span class="ratio c-${a.cls}">${a.ratio.toFixed(2)}</span></div>
    <div class="zone c-${a.cls}">${a.zone}</div>
    <div class="meter"><span class="pin" style="right:${pos}%"></span></div>
    <div class="adv">${a.advice}<br>حمل آخر 7 أيام: <b>${Math.round(a.acute)}</b> · متوسطك الأسبوعي (28 يوم): <b>${Math.round(a.chronicWeekly)}</b></div></div>`; }
function renderAcwr(){ const h=acwrHTML(); const t=document.getElementById('acwrTrain'); if(t)t.innerHTML=h; const an=document.getElementById('acwrAn'); if(an)an.innerHTML=h; }

// ---- auto yesterday ----
function mapSession(s){ const r=s.rpe;
  if(s.type==='strength'||s.type==='speed')return r>=7?'str_hard':r>=4?'str_mid':'str_light';
  if(s.type==='endurance')return r>=7?'endur_hard':r>=4?'endur_mid':'endur_light';
  if(s.type==='match')return r>=7?'endur_hard':'endur_mid';
  return r>=7?'endur_mid':'endur_light'; }
function autoYesterday(){ const y=daysAgoISO(1); const ses=state.trainLog.filter(s=>s.dateISO===y);
  if(ses.length){ let best=null; ses.forEach(s=>{const m=mapSession(s); if(!best||RANK[m]>RANK[best])best=m;}); return best; }
  const recent=state.trainLog.some(s=>s.dateISO&&daysBetween(s.dateISO,todayISO())<=7); return recent?'rest':null; }

// ---- daily check ----
function buildScales(){ document.querySelectorAll('#v-daily .scale').forEach(sc=>{ const k=sc.dataset.k; sc.innerHTML='';
  for(let i=1;i<=5;i++){ const b=document.createElement('button'); b.textContent=i; if(state.daily[k]===i)b.classList.add('on'); b.onclick=()=>{state.daily[k]=i;buildScales();}; sc.appendChild(b);} }); }
function buildYest(){ const c=document.getElementById('yopts'); c.innerHTML='';
  YEST.forEach(([k,lbl])=>{ const b=document.createElement('button'); if(state.daily.yesterday===k)b.classList.add('on'); b.innerHTML=`<span class="ed"></span>${lbl}`;
    b.onclick=()=>{state.daily.yesterday=k;autoFilled=false;buildYest();}; c.appendChild(b); });
  document.getElementById('yHint').innerHTML=autoFilled?'<div class="autohint">✓ مُعبّأة تلقائياً من سجل تدريبك — يمكنك تغييرها</div>':''; }
function sleepHours(bed,wake){ if(!bed||!wake)return null; const[bh,bm]=bed.split(':').map(Number),[wh,wm]=wake.split(':').map(Number);
  let mins=(wh*60+wm)-(bh*60+bm); if(mins<=0)mins+=1440; return mins/60; }
function baseline(field){ const h=state.dailyLog.map(l=>l[field]).filter(v=>v!=null&&!isNaN(v)).map(Number); if(h.length<2)return null; const r=h.slice(-10); return avg(r); }

// pattern helpers
function consecBad(){ let c=0; for(let i=state.dailyLog.length-1;i>=0;i--){ const v=state.dailyLog[i].verdict; if(v&&v!=='green')c++; else break; } return c; }
function rhrRising(){ const b=state.dailyLog.map(l=>l.bpm).filter(v=>v); if(b.length<6)return 0; const last3=avg(b.slice(-3)),prev=avg(b.slice(-10,-3)); const d=last3-prev; return d>=4?d:0; }
function sleepShort(){ const s=state.dailyLog.map(l=>l.sleepH).filter(v=>v!=null); if(s.length<3)return false; return avg(s.slice(-3))<6.5; }

// ---- THE SMART ENGINE v2 ----
function engine(inp){
  let reasons=[],pPow=0,pMus=0,pAer=0,pGen=0;
  if(inp.bpm&&inp.rhrBase){ const d=Math.round(inp.bpm-inp.rhrBase);
    if(d>=10){pAer+=3;pGen+=2;reasons.push(`نبضك أعلى بـ ${d} نبضة عن معدّلك — إجهاد واضح`);}
    else if(d>=7){pAer+=2;pGen+=1;reasons.push(`نبضك أعلى بـ ${d} نبضة — انتبه`);}
    else if(d>=4){pAer+=1;reasons.push(`نبضك أعلى قليلاً (+${d})`);}
    else if(d<=-2){reasons.push('نبضك منخفض — تعافٍ جيد 👍');} }
  if(inp.sleepH!=null){ const h=inp.sleepH;
    if(h<5){pGen+=3;pAer+=1;reasons.push(`نوم قليل جداً (${h.toFixed(1)}س)`);}
    else if(h<6.5){pGen+=2;reasons.push(`نوم ناقص (${h.toFixed(1)}س)`);}
    else if(h<7.5){pGen+=1;reasons.push(`نوم أقل من المثالي (${h.toFixed(1)}س)`);}
    else if(h>9.5){pGen+=1;reasons.push(`نوم طويل جداً (${h.toFixed(1)}س)`);}
    else reasons.push(`نوم جيد (${h.toFixed(1)}س) 👍`); }
  if(inp.bedLate){pGen+=0.5;reasons.push('سهرت متأخراً جداً — يضعف جودة النوم');}
  if(inp.jump&&inp.jumpBase){ const pct=(inp.jump-inp.jumpBase)/inp.jumpBase*100;
    if(pct<=-8){pPow+=3;reasons.push(`قفزتك أقل ${Math.abs(pct).toFixed(0)}% — إرهاق عصبي عضلي`);}
    else if(pct<=-5){pPow+=2;reasons.push(`قفزتك أقل ${Math.abs(pct).toFixed(0)}%`);}
    else if(pct>=4){reasons.push('قفزتك ممتازة اليوم 💥');} }
  if(inp.balance&&inp.balBase){ const pct=(inp.balance-inp.balBase)/inp.balBase*100; if(pct<=-20){pPow+=1;reasons.push('توازنك أضعف — جهازك العصبي متعب');} }
  if(inp.flex!=null&&inp.flexBase!=null&&inp.flex<inp.flexBase-3){pMus+=1;reasons.push('مرونتك أقل — عضلاتك متيبّسة');}
  if(inp.soreness<=2){pMus+=2;reasons.push('ألم عضلي واضح');} else if(inp.soreness===3){pMus+=1;}
  if(inp.energy<=2){pGen+=2;pPow+=1;reasons.push('طاقة منخفضة');} else if(inp.energy>=5){reasons.push('طاقة عالية 👍');}
  if(inp.mood<=2){pGen+=1;reasons.push('دافعية منخفضة');}
  if(inp.stress<=2){pGen+=1;pAer+=1;reasons.push('توتر مرتفع');}
  const y=inp.yesterday;
  if(y==='str_hard'){pMus+=3;pPow+=2;reasons.push('قوة قاسية أمس — عضلاتك تحتاج ~48س تعافٍ');}
  else if(y==='str_mid'){pMus+=1.5;reasons.push('قوة متوسطة أمس');}
  else if(y==='str_light'){pMus+=0.5;}
  else if(y==='endur_hard'){pAer+=3;pGen+=1;reasons.push('تحمّل قاسٍ أمس — جهازك يحتاج تعافياً');}
  else if(y==='endur_mid'){pAer+=1.5;reasons.push('تحمّل متوسط أمس');}
  else if(y==='endur_light'){pAer+=0.5;}
  else if(y==='rest'){reasons.push('ارتحت أمس — جسمك أنشط اليوم 👍');}
  // v2: multi-day intelligence
  const a=acwrCalc();
  if(a.ok&&a.ratio>1.5){pGen+=2;reasons.push(`حملك الأسبوعي قفز بسرعة (ACWR ${a.ratio.toFixed(2)}) — خطر إصابة`);}
  else if(a.ok&&a.ratio>1.3){pGen+=1;reasons.push(`حملك الأسبوعي مرتفع (ACWR ${a.ratio.toFixed(2)})`);}
  const cb=consecBad(); if(cb>=3){pGen+=1.5;reasons.push(`${cb} أيام متتالية بدون جاهزية خضراء — جسمك يطلب تخفيفاً`);}
  const rr=rhrRising(); if(rr){pAer+=1.5;reasons.push(`نبض راحتك يرتفع تدريجياً عبر الأيام (+${Math.round(rr)}) — إنذار مبكر`);}
  if(sleepShort()){pGen+=1;reasons.push('متوسط نومك آخر 3 ليالٍ منخفض — دين نوم متراكم');}

  const lv=p=>p>=4?'no':p>=2.5?'low':p>=1?'mid':'full';
  const weights=lv(pMus+pPow*0.5+pGen*0.4);
  const sprint=lv(pPow+pMus*0.5+pGen*0.4);
  const endurance=lv(pAer+pGen*0.4);
  const skillP=pGen*0.5+pPow*0.3; const skill=skillP>=4?'low':skillP>=2.2?'mid':'full';
  const total=pPow+pMus+pAer+pGen;
  let verdict=total<=1.5?'green':(total>=8||weights==='no'||sprint==='no'||endurance==='no')?'red':'amber';
  const title={green:'جاهز للدفع 💪',amber:'تدرّب بحذر ⚠️',red:'يوم تعافٍ 🛑'}[verdict];
  const worst=pPow>=pMus&&pPow>=pAer?'pow':pMus>=pAer?'mus':'aer';
  let tip;
  if(verdict==='red') tip=(cb>=3||(a.ok&&a.ratio>1.5))?'جسمك يطلب أسبوع تخفيف: نصف الحجم، شدّة خفيفة، نوم أطول. هذا استثمار يرفع مستواك بعده.':'جسمك يحتاج تعافياً — استشفاء نشط خفيف أو راحة. الراحة الآن تحميك من التراجع والإصابة.';
  else if(verdict==='green') tip='أنت فريش — استغل اليوم للسرعة والقوة وأنت في أفضل حالة. ادفع بثقة، وسجّل حصتك بعدها في تبويب التدريب.';
  else if(worst==='pow') tip='جهازك الانفجاري متعب — تجنّب الانطلاقات القصوى والأثقال الثقيلة، وركّز على المهارة واللمسة التقنية.';
  else if(worst==='mus') tip='عضلاتك تحتاج راحة — تجنّب الأرجل الثقيلة والانطلاقات، يمكنك مهارة خفيفة أو عمل علوي/جذع.';
  else tip='جهازك يحتاج تعافياً هوائياً — تجنّب التحمّل المكثّف، استشفاء نشط، ويمكن عمل مهارة وتقنية.';
  const advice=`الأسباب: ${reasons.slice(0,5).join(' · ')||'كل المؤشرات جيدة'}.\n\n${tip}`;
  return{verdict,title,weights,sprint,skill,endurance,advice,score:Math.max(0,Math.round(100-total*9))}; }

