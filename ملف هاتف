        )}

        {tab==="rules"&&(
          <div>
            <div style={{fontSize:12,color:"#7EAA87",fontWeight:700,marginBottom:10}}>📋 قانون الحصة</div>
            {ses.rules.map((rule,i)=>{
              const styles={
                banned:{bg:"#1C0A0A",border:"#5C1A1A",icon:"❌",col:"#FFCDD2"},
                allowed:{bg:"#0A1C0C",border:"#1A4020",icon:"✅",col:"#C8E6C9"},
                if:{bg:"#0D1A1F",border:"#1A3A40",icon:"→",col:"#90CAF9"},
              };
              const st=styles[rule.type]||styles.if;
              return(
                <div key={i} style={{background:st.bg,border:`1px solid ${st.border}`,borderRadius:10,padding:"10px 13px",marginBottom:8,display:"flex",gap:10,alignItems:"flex-start"}}>
                  <span style={{fontSize:16}}>{st.icon}</span>
                  <div>
                    {rule.type==="if"&&<div style={{fontSize:11,color:st.col,marginBottom:3}}>إذا كان: {rule.condition}</div>}
                    <div style={{color:rule.type==="if"?"#E3F2FD":st.col,fontSize:13,fontWeight:rule.type==="if"?700:600}}>{rule.type==="if"?rule.action:rule.text}</div>
                  </div>
                </div>
              );
            })}
          </div>
        )}

        <div style={{background:"#0D1F0F",border:"1px solid #1A3A22",borderRadius:14,padding:"13px 15px",marginTop:12}}>
          <div style={{fontSize:11,color:"#7EAA87",fontWeight:700,marginBottom:10}}>⚽ دليل القرار السريع</div>
          {[{c:"لاعب واحد أمامك",a:"هاجمه",col:"#22C55E"},{c:"لاعبان أمامك",a:"مرر وتحرك",col:"#F5A623"},{c:"قريب من المرمى",a:"سدد بسرعة",col:"#42A5F5"},{c:"تعبان",a:"العب أبسط",col:"#EF9A9A"}]
          .map(item=>(
            <div key={item.c} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"7px 0",borderBottom:"1px solid #122318"}}>
              <span style={{fontSize:12,color:"#9DBFA4"}}>{item.c}</span>
              <span style={{fontSize:13,fontWeight:800,color:item.col}}>{item.a} ←</span>
            </div>
          ))}
        </div>

        <button onClick={()=>toggleDone(active)}
          style={{width:"100%",marginTop:14,padding:"13px",borderRadius:14,border:`2px solid ${completed.includes(active)?"#22C55E":ses.color}`,background:completed.includes(active)?"#0D2A12":`${ses.color}18`,color:completed.includes(active)?"#22C55E":"#EDECEA",fontSize:14,fontWeight:800,cursor:"pointer",fontFamily:"inherit"}}>
          {completed.includes(active)?"✅ الحصة اكتملت!":"🏁 علّم الحصة كمكتملة"}
        </button>
        <div style={{height:40}}/>
      </div>
    </div>
  );
}

