// ─── REST TIMER ───────────────────────────────────────────────────────────────
function RestTimer({ seconds, color, onDone }) {
  const [left, setLeft] = useState(seconds);
  const [run, setRun]   = useState(true);
  const ref = useRef(null);

  useEffect(() => {
    if(run){ ref.current = setInterval(()=>{ setLeft(t=>{ if(t<=1){clearInterval(ref.current);setRun(false);onDone&&onDone();return 0;}return t-1;}); },1000); }
    return ()=>clearInterval(ref.current);
  },[run]);

  const pct = (left/seconds)*100;
  const m=Math.floor(left/60), s=left%60;
  return (
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.85)",display:"flex",alignItems:"center",justifyContent:"center",zIndex:999}}>
      <div style={{background:"#111827",borderRadius:24,padding:"36px 40px",textAlign:"center",minWidth:260,border:`2px solid ${color}`}}>
        <div style={{fontSize:13,color:"#8b9ab0",marginBottom:8}}>⏸ وقت الراحة</div>
        <div style={{position:"relative",width:120,height:120,margin:"0 auto 20px"}}>
          <svg viewBox="0 0 120 120" style={{transform:"rotate(-90deg)"}}>
            <circle cx="60" cy="60" r="54" fill="none" stroke="#1a2235" strokeWidth="10"/>
            <circle cx="60" cy="60" r="54" fill="none" stroke={color} strokeWidth="10"
              strokeDasharray={`${2*Math.PI*54}`}
              strokeDashoffset={`${2*Math.PI*54*(1-pct/100)}`}
              strokeLinecap="round" style={{transition:"stroke-dashoffset 1s linear"}}/>
          </svg>
          <div style={{position:"absolute",inset:0,display:"flex",alignItems:"center",justifyContent:"center",fontSize:28,fontWeight:900,color:"#fff"}}>
            {`${String(m).padStart(2,"0")}:${String(s).padStart(2,"0")}`}
          </div>
        </div>
        <button onClick={()=>{clearInterval(ref.current);onDone&&onDone();}} style={{background:color,color:"#fff",border:"none",borderRadius:12,padding:"10px 28px",fontSize:14,fontWeight:700,cursor:"pointer",fontFamily:"inherit"}}>تخطى ⏭</button>
      </div>
    </div>
  );
}

