// FIX: حلقة التقدم — تستثني يوم الراحة من العدد الكلي
function OverallRing({ days, dayProg }) {
  const activeDays = days.filter(d => !d.rest); // FIX: أيام التدريب فقط
  const total = activeDays.length;
  const done  = activeDays.filter(d => dayProg(d) === 100).length;
  const pct   = total ? Math.round((done/total)*100) : 0;
  const r=28, circ=2*Math.PI*r;
  return (
    <div style={{display:"flex",alignItems:"center",gap:14,background:"#111827",borderRadius:16,padding:"12px 16px",marginTop:16,border:"1px solid #1a2235"}}>
      <svg width="70" height="70" viewBox="0 0 70 70">
        <circle cx="35" cy="35" r={r} fill="none" stroke="#1a2235" strokeWidth="8"/>
        <circle cx="35" cy="35" r={r} fill="none" stroke="#00C853" strokeWidth="8"
          strokeDasharray={circ} strokeDashoffset={circ*(1-pct/100)}
          strokeLinecap="round" transform="rotate(-90 35 35)" style={{transition:"stroke-dashoffset 0.5s"}}/>
        <text x="35" y="40" textAnchor="middle" fill="#fff" fontSize="13" fontWeight="900">{pct}%</text>
      </svg>
      <div>
        <div style={{color:"#e8edf5",fontWeight:700,fontSize:15}}>تقدم الأسبوع</div>
        {/* FIX: "6 أيام تدريب" بدلاً من "7 أيام" */}
        <div style={{color:"#8b9ab0",fontSize:13,marginTop:3}}>{done} من {total} أيام تدريب مكتملة</div>
        <div style={{color:"#00C853",fontSize:12,marginTop:3,fontWeight:600}}>
          {pct===100?"🏆 أسبوع مثالي!":pct>=50?"💪 نصف الطريق":pct>0?"⚡ بداية موفقة":"🎯 ابدأ الآن"}
        </div>
      </div>
    </div>
  );
}

// ─── DAY VIEW ─────────────────────────────────────────────────────────────────
function DayView({ day, onBack, doneExs, toggleEx, clearDay, onEvening }) {
  const [openEx, setOpenEx] = useState(null);
  const [restTimer, setRestTimer] = useState(null);
  const togEx = (k) => setOpenEx(openEx===k ? null : k);
  const pct = (() => {
    if (day.rest) return null;
    const total = day.sessions.flatMap(s=>s.exercises).length;
    if (!total) return 0;
    const done = day.sessions.flatMap((s,si)=>s.exercises.map((_,ei)=>`d${day.id}-${si}-${ei}`)).filter(k=>doneExs[k]).length;
    return Math.round((done/total)*100);
  })();

  return (
    <div style={{...S.root,display:"flex",flexDirection:"column"}}>
      <div style={{...S.dayHdr,background:day.gradient}}>
        {/* FIX: السهم يتجه للخلف صحيح في RTL */}
        <button onClick={onBack} style={S.backBtn}><Chev/></button>
        <button onClick={()=>clearDay(day.id)} style={S.clearBtn} title="مسح التقدم">↺</button>
        <div style={S.dayHdrEmoji}>{day.emoji}</div>
        <div style={S.dayHdrName}>{day.full}</div>
        <div style={S.dayHdrType}>{day.type}</div>
        <div style={{display:"flex",gap:8,justifyContent:"center",marginTop:10}}>
          <div style={S.dayPill}>{day.badge}</div>
          {pct!==null && <div style={{...S.dayPill,background:"rgba(0,0,0,0.4)"}}>{pct}% مكتمل</div>}
        </div>
        {pct!==null && (
          <div style={S.dayProgBar}>
            <div style={{...S.dayProgFill,width:`${pct}%`}}/>
          </div>
        )}
      </div>

      <div style={S.scroll2}>
        {day.alert && (
          <div style={S.alertBox}>
            <span style={{fontSize:18,flexShrink:0}}>⚠️</span>
            <span style={S.alertTxt}>{day.alert}</span>
          </div>
        )}

        {day.rest
          ? <div style={{padding:16}}><RestCard/></div>
          : day.sessions.map((ses,si) => (
              <div key={si} style={S.sesSec}>
                <div style={{...S.sesTagRow,color:day.color}}>
                  <span style={{fontWeight:700}}>{ses.time}</span>
                  <span style={S.sesDurChip}>{ses.duration}</span>
                </div>
                {ses.exercises.map((ex,ei) => {
                  const k = `d${day.id}-${si}-${ei}`;
                  return (
                    <ExCard key={ei} ex={ex} color={day.color}
                      open={openEx===`${si}-${ei}`}
                      onToggle={()=>togEx(`${si}-${ei}`)}
                      done={!!doneExs[k]}
                      onDone={()=>toggleEx(k)}
                      onTimer={sec=>setRestTimer({sec,color:day.color})}/>
                  );
                })}
              </div>
            ))
        }

        {!day.rest && (
          <div style={{padding:"16px 14px"}}>
            <div style={{...S.eveningCTA,borderColor:day.color+"55"}}>
              <div style={{fontSize:13,color:"#8b9ab0",marginBottom:12,fontWeight:600}}>🌙 الحصة المسائية</div>
              <button onClick={onEvening} style={{...S.eveningBtn,background:day.gradient}}>
                ⚽ لمسات مع الأصدقاء أو تنطيط
              </button>
            </div>
          </div>
        )}
        <div style={{height:30}}/>
      </div>

      {restTimer && (
        <RestTimer seconds={restTimer.sec} color={restTimer.color} onDone={()=>setRestTimer(null)}/>
      )}
    </div>
  );
}

// ─── EXERCISE CARD ────────────────────────────────────────────────────────────
function ExCard({ ex, color, open, onToggle, done, onDone, onTimer }) {
  const parseRest = (s) => {
    if(!s) return null;
    const m=s.match(/(\d+)\s*ثانية/); if(m) return parseInt(m[1]);
    const m2=s.match(/(\d+)\s*دقيقة/); if(m2) return parseInt(m2[1])*60;
    return null;
  };
  const restSec = parseRest(ex.rest);

  return (
    <div style={{...S.exWrap,opacity:done?0.72:1}}>
      <button onClick={onToggle} style={{...S.exCard,borderColor:ex.star?"#FFD700":open?color:done?"#00C85355":"#1c2535",background:done?"#0d1a0d":"#111827"}}>
        {ex.star&&<div style={S.starBadge}>⭐ أهم تمرين</div>}
        <div style={S.exTop}>
          <div style={{...S.exIconBox,background:done?"#00C853":ex.star?"#FFD700":color}}>
            <span style={{fontSize:15,color:done||!ex.star?"#fff":ex.star?"#000":"#fff"}}>{done?"✓":ex.icon}</span>
          </div>
          <div style={{flex:1}}>
            <div style={{...S.exName,color:ex.star?"#FFD700":done?"#00C853":"#e8edf5",textDecoration:done?"line-through":"none"}}>{ex.name}</div>
            <div style={S.exChips}>
              {ex.sets&&<span style={{...S.chip,background:color+"22",color}}>{ex.sets}</span>}
              {ex.reps&&<span style={{...S.chip,background:"#1c2535",color:"#aaa"}}>{ex.reps}</span>}
              {ex.rest&&<span style={{...S.chip,background:"#1c2535",color:"#667"}}>⏸ {ex.rest}</span>}
            </div>
          </div>
          <span style={{color:open?color:"#334",fontSize:13,transform:open?"rotate(180deg)":"none",transition:"transform 0.2s",flexShrink:0}}>▼</span>
        </div>

        {open && (
          <div style={S.exBody}>
            {ex.img&&IMGS[ex.img]&&<img src={IMGS[ex.img]} alt={ex.name} style={S.exImg}/>}
            {ex.note&&<div style={S.exNote}>{ex.note}</div>}
            {ex.subNote&&<div style={{...S.exNote,background:"#0d1a2e",color:"#6aabff",marginTop:6}}>{ex.subNote}</div>}
            {ex.steps&&(
              <div style={S.stepsWrap}>
                {ex.steps.map((s,i)=>(
                  <div key={i} style={S.stepItem}>
                    <div style={{...S.stepBub,background:ex.star?"#FFD700":color,color:ex.star?"#000":"#fff"}}>{s}</div>
                    {i<ex.steps.length-1&&<span style={{color:"#445",fontSize:16}}>←</span>}
                  </div>
                ))}
              </div>
            )}
            {ex.heavy&&<div style={S.heavyNote}>🏋️ وزن ثقيل جداً — أداء صحيح أولاً</div>}
            {ex.brain&&<div style={S.brainNote}>🧠 قرار سريع تحت الضغط — تدريب عقلي</div>}
            <div style={{display:"flex",gap:8,marginTop:12}}>
              <button onClick={(e)=>{e.stopPropagation();onDone();}}
                style={{...S.doneBtn,background:done?"#00C853":"transparent",color:done?"#fff":"#00C853",border:"1px solid #00C853"}}>
                {done?"✅ تم!":"✓ علّم كمكتمل"}
              </button>
              {restSec&&!done&&(
                <button onClick={(e)=>{e.stopPropagation();onTimer(restSec);}}
                  style={{...S.doneBtn,color:color,border:`1px solid ${color}`}}>
                  ⏱ مؤقت الراحة
                </button>
              )}
            </div>
          </div>
        )}
      </button>
    </div>
  );
}

