      )}
      {view==="week" && (
        <WeekView days={DAYS} onDay={i=>{setSelDay(i);setView("day");}} dayProg={dayProgress}/>
      )}
      {view==="day" && selDay!==null && (
        <DayView day={DAYS[selDay]} onBack={()=>setView("week")}
          doneExs={doneExs} toggleEx={toggleEx} clearDay={clearDay}
          onEvening={()=>{setEveningDay(selDay);setView("evening");}}/>
      )}
      {view==="evening" && (
        <EveningView
          day={eveningDay!==null ? DAYS[eveningDay] : null}
          onBack={()=>setView(selDay!==null?"day":"week")}/>
      )}
    </div>
  );
}

